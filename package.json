{
  "name": "skill-bridge",
  "version": "1.0.0",
  "description": "Full-stack SaaS platform connecting people who need help with people who have skills.",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd front && npm run dev",
    "test:backend": "cd backend && npm test",
    "build:frontend": "cd front && npm run build",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md}\" --ignore-path .prettierignore"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codermayur/Skill_Bridge.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "cors": "^2.8.6"
  }
}
